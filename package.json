{
  "name": "n8n-nodes-marqeta",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Marqeta card issuing platform providing 27 resources and 200+ operations for card program management, user lifecycle, transactions, KYC, digital wallets, and real-time decisioning.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-marqeta.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-marqeta#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-marqeta/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "marqeta",
    "card-issuing",
    "payments",
    "fintech",
    "card-program",
    "kyc",
    "digital-wallet",
    "apple-pay",
    "google-pay",
    "debit-cards",
    "prepaid-cards",
    "card-management",
    "transaction-processing",
    "velocity-controls",
    "jit-funding"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MarqetaApi.credentials.js",
      "dist/credentials/MarqetaProgram.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Marqeta/Marqeta.node.js",
      "dist/nodes/Marqeta/MarqetaTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.35.0",
    "prettier": "^3.3.1",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "uuid": "^9.0.1"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
